# ==============================================================================
# EURABAY Living System - Local Development Environment Variables
# ==============================================================================
# Copy this file to .env.local and configure values for your local environment

# ==============================================================================
# Application URLs
# ==============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================================================
# Backend API Configuration
# ==============================================================================
# Base URL for the backend API (Python FastAPI server)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# WebSocket URL for real-time updates
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Disable WebSocket connection (for frontend-only testing without backend server)
# Set to 'true' to disable WebSocket client initialization
# NEXT_PUBLIC_WS_DISABLED=true

# API request timeout in milliseconds (default: 30000)
NEXT_PUBLIC_API_TIMEOUT=30000

# ==============================================================================
# Authentication API (Better Auth)
# ==============================================================================
NEXT_PUBLIC_AUTH_API_URL=/api/auth

# ==============================================================================
# Database Configuration
# ==============================================================================
# For local development, defaults to file:.local/db.sqlite (no vars needed)
# For production (Turso), uncomment and configure:

# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=

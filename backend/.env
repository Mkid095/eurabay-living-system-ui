# EURABAY Living System - Environment Configuration
# Copy this file to .env and update with your settings

# Application Settings
APP_NAME=EURABAY Living System
VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Server Settings
HOST=127.0.0.1
PORT=8000

# CORS Settings (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Trading Symbols (volatility indices)
TRADING_SYMBOLS=V10,V25,V50,V75,V100

# MT5 Connection Settings
# MetaTrader5 terminal must be running and logged in for trading
# MT5_PATH=C:\\Program Files\\MetaTrader 5 Terminal\\terminal64.exe
MT5_ACCOUNT=32073468
MT5_PASSWORD=Elishiba@95
MT5_SERVER=Deriv-Demo

# Risk Management Settings
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
MAX_CONCURRENT_POSITIONS=3
MIN_RISK_REWARD_RATIO=1.5

# Trading Settings
TRADING_ENABLED=false
PAPER_TRADING=true

# Database Settings
DATABASE_PATH=backend/data/trading.db

# Data Storage Settings
DATA_DIR=backend/data
LOG_DIR=backend/logs

# Model Settings
MODEL_DIR=backend/data/models
RETRAIN_INTERVAL_DAYS=7

# WebSocket Settings
WS_HEARTBEAT_INTERVAL=30
